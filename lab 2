%% KdV Analysis Script
clear; close all; clc;


g = 9.81;                 
h0 = 32.45e-3;             
dx = 0.3125e-3;            

numTrials = 5;

eta_min = -2.2575e-2;  % meters
eta_max = 1.5310e-2;   % meters

for trial = 1:numTrials

    %% trial data
    filename = sprintf('%dsurface_data.mat', trial);
    load(filename);
    fprintf('\n=== Trial %d ===\n', trial);

    
    x = xPixels * dx;       
    eta = deviation * dx;   

    %% Limit time to 20 s, above this is just noise
    t_limit = 20;
    time_plot = time(time <= t_limit);
    eta_plot  = eta(time <= t_limit, :);

   
    % 1. x–t Diagram
   
    figure('Position',[200 200 900 550],'Color','w');
    imagesc(x, time_plot, eta_plot);
    set(gca,'YDir','normal');

    colormap(parula);  
    caxis([eta_min eta_max]);   % uniform scaling
    cb = colorbar;
    cb.Label.String = '$\eta$ (m)';
    cb.Label.Interpreter = 'latex';

    xlabel('$x$ (m)','Interpreter','latex','FontSize',16)
    ylabel('$t$ (s)','Interpreter','latex','FontSize',16)
    title(sprintf('Trial %d: x--t Diagram',trial),'FontSize',17)
    set(gca,'FontSize',14,'LineWidth',1.6,'Box','on',...
        'TickDir','out','TickLength',[0.015 0.015]);
    grid on

    % 2. Wave Speed & Eta from Manual x-t Slope
    fprintf('Click two points along the main wave ridge in the figure.\n');
    [x_click, t_click] = ginput(2);

    % wave speed
    wave_speed = abs(diff(x_click) / diff(t_click));
    fprintf('Estimated wave speed from x-t diagram: %.4f m/s\n', wave_speed);

    % Get eta values at clicked points
    eta_click = zeros(size(x_click));
    for i = 1:length(x_click)
        [~, ix] = min(abs(x - x_click(i)));
        [~, it] = min(abs(time_plot - t_click(i)));

        % eta value
        eta_click(i) = eta_plot(it, ix);
    end

    %eta at clicked points
    for i = 1:length(x_click)
        fprintf('Point %d: x = %.4f m, t = %.4f s, eta = %.5f m\n', ...
                i, x_click(i), t_click(i), eta_click(i));
    end

end

