%% KdV Wave Collapse with Noise Reduction above threshold
clear; close all; clc;

%% Constants
g = 9.81;                  
h0 = 32.45e-3;             
dx = 0.3125e-3;            
numTrials = 5;
tmax = 15;                 
sgolayWindow = 21;         % smoothing window (must be odd)

figure('Color','w','Position',[200 200 900 550]);
hold on;
colors = turbo(numTrials);

for trial = 1:numTrials
    
    
    filename = sprintf('%dsurface_data.mat', trial);
    load(filename);

   
    it = find(time <= tmax);
    t = time(it);
    
    
    eta_t = deviation(it,:) * dx;
    x = xPixels * dx;

    % Smooth each spatial profile to reduce pixel noise
    eta_t_smooth = smoothdata(eta_t, 2, 'sgolay', sgolayWindow);

    % ind largest-magnitude crest/trough event
    [~, idx_flat] = max(abs(eta_t_smooth(:)));
    [it_peak, ix_peak] = ind2sub(size(eta_t_smooth), idx_flat);

    profile = eta_t_smooth(it_peak, :);

    A = eta_t_smooth(it_peak, ix_peak);
    if A < 0
        profile = -profile;
        A = -A;
    end

    profile = profile - median(profile);

    profile = profile / max(profile);

    x_centered = x - x(ix_peak);

    x_scaled = x_centered * sqrt(3*A/(4*h0^3));
    eta_scaled = profile;

    keep = abs(x_scaled) <= 6;


    plot(x_scaled(keep), eta_scaled(keep), ...
        'Color', colors(trial,:), ...
        'LineWidth', 2)
end

